{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://novel-scout.local/schemas/rulepack.schema.json",
  "title": "Novel Scout versioned rule pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "version",
    "status",
    "locale",
    "title",
    "description",
    "releasedAt",
    "communityContext",
    "sourceCatalog",
    "severityLevels",
    "detectionProfiles",
    "defaults",
    "rules"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "id": { "$ref": "#/$defs/machineId" },
    "version": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["seed", "draft", "reviewed", "published", "deprecated"]
    },
    "locale": { "type": "string", "pattern": "^[a-z]{2,3}(?:-[A-Z]{2})?$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "releasedAt": { "type": "string", "format": "date" },
    "supersedes": { "type": ["string", "null"] },
    "communityContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["community", "scope", "disclaimer", "expectedCategoryCounts"],
      "properties": {
        "community": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "disclaimer": { "type": "string", "minLength": 1 },
        "expectedCategoryCounts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["landmine", "frustration"],
          "properties": {
            "landmine": { "type": "integer", "minimum": 0 },
            "frustration": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "sourceCatalog": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },
    "severityLevels": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/severityLevel" }
    },
    "detectionProfiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/detectionProfile" }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unverifiedRulesEnabled",
        "defaultFindingState",
        "duplicateConceptPolicy",
        "categorySeverity"
      ],
      "properties": {
        "unverifiedRulesEnabled": { "type": "boolean" },
        "defaultFindingState": { "$ref": "#/$defs/findingState" },
        "duplicateConceptPolicy": {
          "enum": ["highest_user_selected_severity", "keep_separate", "ask_user"]
        },
        "categorySeverity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["landmine", "frustration"],
          "properties": {
            "landmine": { "$ref": "#/$defs/severityId" },
            "frustration": { "$ref": "#/$defs/severityId" }
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "machineId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "severityId": {
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "findingState": {
      "enum": ["suspected", "pending_confirmation", "confirmed", "rejected"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "title", "accessedAt", "verification", "note"],
      "properties": {
        "id": { "$ref": "#/$defs/machineId" },
        "kind": {
          "enum": ["community_post", "community_index", "user_requirement", "project_note"]
        },
        "title": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "format": "uri" },
        "publishedAt": { "type": "string", "format": "date" },
        "accessedAt": { "type": "string", "format": "date" },
        "verification": {
          "enum": ["unverified", "metadata_only", "partially_verified", "verified"]
        },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "severityLevel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "rank", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/severityId" },
        "label": { "type": "string", "minLength": 1 },
        "rank": { "type": "integer", "minimum": 0 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "detectionProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "findingStates",
        "minEvidenceSnippets",
        "requiresSourceLocator",
        "requiresOriginalTextCheck",
        "rules"
      ],
      "properties": {
        "findingStates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/findingState" }
        },
        "minEvidenceSnippets": { "type": "integer", "minimum": 1 },
        "requiresSourceLocator": { "type": "boolean" },
        "requiresOriginalTextCheck": { "type": "boolean" },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "conceptId",
        "version",
        "category",
        "name",
        "nameStatus",
        "aliases",
        "description",
        "status",
        "defaultEnabled",
        "defaultSeverity",
        "userConfig",
        "detection",
        "provenance",
        "tags"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/machineId" },
        "conceptId": { "$ref": "#/$defs/machineId" },
        "version": { "type": "integer", "minimum": 1 },
        "category": { "enum": ["landmine", "frustration"] },
        "name": { "type": "string", "minLength": 1 },
        "nameStatus": {
          "enum": [
            "verified_community_term",
            "observed_term_definition_unverified",
            "product_draft",
            "placeholder"
          ]
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "description": { "type": "string", "minLength": 1 },
        "status": { "enum": ["seed", "draft", "verified", "deprecated"] },
        "defaultEnabled": { "type": "boolean" },
        "defaultSeverity": { "$ref": "#/$defs/severityId" },
        "userConfig": {
          "type": "object",
          "additionalProperties": false,
          "required": ["toggleable", "severityOverride", "customBoundaryAllowed"],
          "properties": {
            "toggleable": { "type": "boolean" },
            "severityOverride": { "type": "boolean" },
            "customBoundaryAllowed": { "type": "boolean" }
          }
        },
        "detection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "profileRef",
            "mode",
            "criteria",
            "exclusions",
            "pendingConditions",
            "confirmationScope",
            "requiresUserBoundary"
          ],
          "properties": {
            "profileRef": { "$ref": "#/$defs/machineId" },
            "mode": { "enum": ["semantic", "manual_only"] },
            "criteria": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "exclusions": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "pendingConditions": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "confirmationScope": {
              "enum": ["local", "chapter", "cross_chapter", "whole_book"]
            },
            "requiresUserBoundary": { "type": "boolean" }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["verification", "sourceRefs", "note"],
          "properties": {
            "verification": {
              "enum": ["unverified", "term_observed", "definition_partially_verified", "verified"]
            },
            "sourceRefs": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/machineId" }
            },
            "note": { "type": "string", "minLength": 1 }
          }
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/machineId" }
        }
      }
    }
  }
}
