{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://novel-scout.local/schemas/rule-selection.schema.json",
  "title": "Novel Scout user rule selection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "packId", "packVersion", "pendingFindingPolicy", "duplicateConceptPolicy", "overrides"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "packId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "packVersion": { "type": "string", "minLength": 1 },
    "pendingFindingPolicy": {
      "enum": ["show", "hide", "show_above_confidence"]
    },
    "pendingConfidenceThreshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "duplicateConceptPolicy": {
      "enum": ["highest_user_selected_severity", "keep_separate", "ask_user"]
    },
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ruleId"],
        "properties": {
          "ruleId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "enabled": { "type": "boolean" },
          "severity": { "enum": ["critical", "high", "medium", "low", "info"] },
          "sensitivity": { "enum": ["strict", "balanced", "high_recall"] },
          "customBoundary": { "type": "string", "minLength": 1 },
          "note": { "type": "string" }
        },
        "anyOf": [
          { "required": ["enabled"] },
          { "required": ["severity"] },
          { "required": ["sensitivity"] },
          { "required": ["customBoundary"] },
          { "required": ["note"] }
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "pendingFindingPolicy": { "const": "show_above_confidence" } },
        "required": ["pendingFindingPolicy"]
      },
      "then": { "required": ["pendingConfidenceThreshold"] }
    }
  ]
}
