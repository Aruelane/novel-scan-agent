  "detectionProfiles": {
    "strict-evidence-v1": {
      "findingStates": ["suspected", "pending_confirmation", "confirmed", "rejected"],
      "minEvidenceSnippets": 1,
      "requiresSourceLocator": true,
      "requiresOriginalTextCheck": true,
      "rules": [
        "confirmed 必须有可回到原文件的章节及段落、页码或行号定位。",
        "传闻、角色误判、梦境、假设句、比喻和模型补全只能进入 suspected 或 pending_confirmation。",
        "后文可能反转的关系事实在全书交叉核验前不得标为 confirmed。",
        "报告需区分原文事实、模型推断和等待后文确认的线索。"
      ]
    }
  },
  "defaults": {
    "unverifiedRulesEnabled": false,
    "defaultFindingState": "suspected",
    "duplicateConceptPolicy": "highest_user_selected_severity",
    "categorySeverity": {
      "landmine": "critical",
      "frustration": "medium"
    }
  },
  "rules": [
    {
      "id": "yy.thunder.accepting-prior-partner",
      "conceptId": "relationship.accepting-prior-partner",
      "version": 1,
      "category": "landmine",
      "name": "接盘（雷点档；定义待核验）",
      "nameStatus": "observed_term_definition_unverified",
      "aliases": ["接盘"],
      "description": "“接盘”术语及跨档现象已在项目上下文中观察到，但雷点档的具体人物范围、关系史与行为阈值尚未按原帖核验。不得仅凭角色有过恋爱史自动判定。",
      "status": "draft",
      "defaultEnabled": false,
      "defaultSeverity": "critical",
      "userConfig": { "toggleable": true, "severityOverride": true, "customBoundaryAllowed": true },
      "detection": {
        "profileRef": "strict-evidence-v1",
        "mode": "semantic",
        "criteria": ["原文给出与目标角色既往或当前亲密关系有关的明确事实，且达到用户自定义的雷点档边界。"],
        "exclusions": ["只有角色传闻、恶意造谣、误会或模型推测。", "仅凭角色存在普通社交或未落实的追求者。"],
        "pendingConditions": ["关系事实尚未揭晓或后文可能澄清。", "用户未设置个人边界且社区原定义尚未核验。"],
        "confirmationScope": "whole_book",
        "requiresUserBoundary": true
      },
      "provenance": {
        "verification": "term_observed",
        "sourceRefs": ["tieba.post.10485825386", "project.requirement.2026-07-17"],
        "note": "术语可用于界面种子；定义在核验原帖前不得标成正式吧规。"
      },
      "tags": ["relationship", "community-term", "cross-category"]
    },
