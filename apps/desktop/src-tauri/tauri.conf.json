{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "小说扫评 Agent",
  "version": "0.1.0",
  "identifier": "com.novelscout.agent",
  "build": {
    "beforeDevCommand": "node scripts/frontend.mjs dev",
    "beforeBuildCommand": "node scripts/frontend.mjs build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../client/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "小说扫评 Agent",
        "width": 1240,
        "height": 800,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "capabilities": ["main-local"],
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "可追溯证据的网络小说扫雷工具",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:novel-scout.db"]
    }
  }
}
